# Cooksy Environment Configuration

# Core Configuration
EXPO_PUBLIC_RECIPE_IMPORT_MODE=auto
EXPO_PUBLIC_SUPABASE_URL=https://qirjjbmrgtailifhmakp.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Extraction Layer Configuration

# RapidAPI (for TikTok extraction - recommended)
EXPO_PUBLIC_RAPIDAPI_KEY=
EXPO_PUBLIC_RAPIDAPI_HOST=tiktok-api.p.rapidapi.com

# OpenAI (for Whisper transcription - optional)
EXPO_PUBLIC_OPENAI_API_KEY=

# Scraping Toggles (may be blocked by platforms)
EXPO_PUBLIC_ENABLE_TIKTOK_SCRAPING=false
EXPO_PUBLIC_ENABLE_INSTAGRAM_SCRAPING=false

# Whisper Transcription
EXPO_PUBLIC_ENABLE_WHISPER_TRANSCRIPTION=false

# Timeouts (milliseconds)
EXPO_PUBLIC_EXTRACTION_TIMEOUT_MS=30000
